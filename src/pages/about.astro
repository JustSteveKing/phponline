---
import Layout from "@/layouts/Layout.astro";
import { PageHeader, Grid, FeatureCard } from "@/components";
import { SITE_CONFIG } from "@/config/site";

const values = [
    {
        title: "Community First",
        description: "We exist to serve the PHP community. Our goal is to highlight the work of creators, contributors, and maintainers across the ecosystem.",
        badge: "Mission"
    },
    {
        title: "Open Source",
        description: "The entire platform is open source. From the scrapers to the UI components, we believe in transparency and community contribution.",
        badge: "Philosophy"
    },
    {
        title: "Zero Noise",
        description: "No ads, no tracking, no fluff. Just the latest PHP news, RFCs, and podcasts delivered in a clean, modern interface.",
        badge: "Experience"
    }
];

const breadcrumbs = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.phponline.dev" },
        { "@type": "ListItem", "position": 2, "name": "About", "item": "https://www.phponline.dev/about" }
    ]
};
---

<Layout 
    title="About | phponline.dev"
    description="Learn about phponline.dev, our mission to unify the PHP community, and how you can contribute to the project."
    ogImage="/og/about.png"
    sd={[breadcrumbs]}
>
    <PageHeader 
        title="ABOUT THE PROJECT" 
        description="The story behind phponline.dev and why we're building the modern homepage for the PHP community."
        badge="Our Story"
    />

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 mb-32">
        <div class="lg:col-span-8">
            <div class="prose prose-slate dark:prose-invert prose-xl max-w-none prose-headings:font-black prose-headings:tracking-tight prose-red">
                <p class="lead text-2xl font-medium text-slate-600 dark:text-slate-400 mb-12">
                    PHP Online was born out of a simple observation: the PHP ecosystem is more vibrant than ever, but its news and updates are scattered across dozens of blogs, mailing lists, and platforms.
                </p>

                <h2>What is phponline.dev?</h2>
                <p>
                    It is a central pulse for everything happening in the world of PHP. We aggregate high-quality content from trusted community sources—including Laravel News, Symfony, PHP.net, and the Internals mailing list—and present it in a unified, searchable, and highly readable format.
                </p>

                <h2>Why does it exist?</h2>
                <p>
                    While RSS readers and social media are great, they often lead to "information silos" or overwhelming noise. We wanted to build a "magazine-style" experience that allows developers to quickly scan what's trending, track the progress of new language features (RFCs), and discover new podcasts without having to jump between ten different sites.
                </p>

                <h2>Built for the Community</h2>
                <p>
                    This isn't a commercial project. It's an open-source initiative designed to support the authors who make the PHP community what it is. That's why we always link back to the original source and provide a "Continue Reading" call-to-action on every article summary.
                </p>
            </div>
        </div>

        <aside class="lg:col-span-4">
            <div class="sticky top-32 space-y-8">
                <div class="bg-red-600 dark:bg-red-700 rounded-2xl p-8 text-white shadow-2xl shadow-red-200 dark:shadow-black/40 relative overflow-hidden">
                    <div class="relative z-10">
                        <h3 class="text-xl font-black mb-4 uppercase tracking-tight">Built With</h3>
                        <ul class="space-y-3 font-bold text-sm text-red-50">
                            <li class="flex items-center gap-2">
                                <div class="w-1.5 h-1.5 rounded-full bg-white/80"></div>
                                Astro 6.0 (Content Layer)
                            </li>
                            <li class="flex items-center gap-2">
                                <div class="w-1.5 h-1.5 rounded-full bg-white/80"></div>
                                Svelte 5 (Interactive)
                            </li>
                            <li class="flex items-center gap-2">
                                <div class="w-1.5 h-1.5 rounded-full bg-white/80"></div>
                                Tailwind CSS 4.0
                            </li>
                            <li class="flex items-center gap-2">
                                <div class="w-1.5 h-1.5 rounded-full bg-white/80"></div>
                                Pagefind (Static Search)
                            </li>
                        </ul>
                    </div>
                    <div class="absolute -bottom-8 -right-8 w-32 h-32 bg-white/10 rounded-full blur-2xl"></div>
                </div>

                <div class="bg-slate-900 dark:bg-[#0f172a] rounded-2xl p-8 text-white border border-transparent dark:border-slate-800/50 shadow-xl dark:shadow-black/20">
                    <h3 class="text-xl font-black mb-4 uppercase tracking-tight">Contribute</h3>
                    <p class="text-slate-400 text-sm font-medium mb-6">
                        Want to add your blog, suggest a feature, or fix a bug?
                    </p>
                    <a 
                        href={SITE_CONFIG.links.github} 
                        target="_blank"
                        class="flex items-center justify-center gap-2 w-full py-3 rounded-full bg-white text-slate-900 font-black text-xs uppercase tracking-widest hover:bg-red-50 transition-colors"
                    >
                        View on GitHub
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                    </a>
                </div>
            </div>
        </aside>
    </div>

    <section class="mb-20">
        <div class="mb-12 border-b border-slate-100 dark:border-slate-800/60 pb-8">
            <h2 class="text-3xl font-black tracking-tight text-slate-900 dark:text-white uppercase">Core Values</h2>
        </div>
        <Grid columns={3} gap="large">
            {values.map(value => (
                <FeatureCard {...value} />
            ))}
        </Grid>
    </section>
</Layout>
