---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import type { CollectionEntry } from 'astro:content';

const allNews = await getCollection('news');
// Sort and Slice to keep the homepage fast
const latestNews = allNews
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6); // Only take the top 6 for the homepage

const rfcItems = allNews.filter(i => i.data.source === 'RFC').slice(0, 3);
---

<Layout>
<main class="max-w-7xl mx-auto p-6 grid grid-cols-1 md:grid-cols-4 md:grid-rows-2 gap-4 h-auto md:h-[80vh]">
  
  <section class="md:col-span-2 md:row-span-2 bg-slate-900 rounded-3xl p-8 text-white flex flex-col justify-between border border-slate-800 shadow-2xl">
    <div>
      <span class="bg-blue-500 text-[10px] font-bold px-2 py-1 rounded-full uppercase tracking-widest">Featured</span>
      <h1 class="text-4xl font-bold mt-4 leading-tight">{latestNews[0].data.title}</h1>
      <p class="mt-4 text-slate-400 line-clamp-3">{latestNews[0].data.content}</p>
    </div>
    <a href={latestNews[0].data.link} class="mt-8 inline-flex items-center text-blue-400 font-semibold hover:underline">
      Read full story →
    </a>
  </section>

  <section class="md:col-span-1 bg-white rounded-3xl p-6 border border-slate-200 overflow-hidden flex flex-col shadow-sm">
    <h3 class="font-bold text-slate-900 mb-4 flex justify-between">
      The Latest 
      <a href="/archive" class="text-xs text-blue-600">View All</a>
    </h3>
    <div class="space-y-4 overflow-y-auto pr-2">
      {latestNews.slice(1).map(item => (
        <div class="group">
          <p class="text-[10px] font-bold text-slate-400 uppercase">{item.data.source}</p>
          <a href={item.data.link} class="text-sm font-medium leading-snug group-hover:text-blue-600 block">
            {item.data.title}
          </a>
        </div>
      ))}
    </div>
  </section>

  <section class="md:col-span-1 bg-blue-50 rounded-3xl p-6 border border-blue-100 shadow-sm">
    <h3 class="font-bold text-blue-900 mb-4 italic font-serif">Future PHP...</h3>
    <ul class="space-y-3">
      {rfcItems.map(rfc => (
        <li class="text-sm flex gap-2">
          <span class="text-blue-400">⚡</span>
          <a href={rfc.data.link} class="hover:underline">{rfc.data.title}</a>
        </li>
      ))}
    </ul>
  </section>

  <section class="md:col-span-2 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-3xl p-6 text-white shadow-lg">
    <div class="flex justify-between items-center">
      <h3 class="font-bold">Latest Podcast</h3>
      <div class="h-8 w-8 bg-white/20 rounded-full flex items-center justify-center">▶️</div>
    </div>
    <p class="mt-2 text-lg font-medium">PHP Ugly: Episode 402 - The FrankenPHP Revolution</p>
  </section>

</main>
</Layout>
