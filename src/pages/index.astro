---
import Layout from "../layouts/Layout.astro";
import {
    BentoCard,
    NewsCard,
    Hero,
    SectionHeading,
    Grid,
    FeatureCard,
    CreatorPill,
    PHPHealthBanner,
    Sidebar,
    SidebarCard,
} from "@/components";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import { YOUTUBE_CHANNELS } from "@/config/feeds";
import { SITE_CONFIG } from "@/config/site";
import { PAGES } from "@/config/pages";

const allNews: CollectionEntry<"news">[] = await getCollection("news");
const allVideos = await getCollection("videos");

const sorted = allNews.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Logic for our Layout
const heroPost = sorted[0];
const subHeroPosts = sorted.slice(1, 4);
const latestStories = sorted.slice(4, 10);

const channelData = YOUTUBE_CHANNELS.map((channel) => {
    const videoCount = allVideos.filter(v => v.data.channel === channel.label).length;
    return {
        ...channel,
        videoCount,
    };
}).slice(0, 8); // Just show top 8 on home

const sd = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE_CONFIG.name,
    url: SITE_CONFIG.url,
    description: SITE_CONFIG.description,
};
---

<Layout
    title={PAGES.home.title}
    description={PAGES.home.description}
    sd={sd}
    ogImage={PAGES.home.ogImage}
>
    <!-- Polished Hero Section -->
    <Hero item={heroPost} />

    <PHPHealthBanner />

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 mb-20">
        <!-- Main Content Area -->
        <div class="lg:col-span-8">
            <SectionHeading title="Trending Now" viewAllHref="/archive/1" />
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {
                    subHeroPosts.map((post, i) => (
                        <BentoCard
                            item={post}
                            class={
                                i === 0
                                    ? "md:col-span-2 h-[400px]"
                                    : "h-[300px]"
                            }
                        />
                    ))
                }
            </div>
        </div>

        <!-- Refined Sidebar -->
        <Sidebar top="top-8">
            <SidebarCard title="The Pulse" badge={true}>
                <div class="space-y-6">
                    {latestStories.map((post) => <NewsCard item={post} />)}
                </div>

                <a
                    href="/archive/1"
                    class="group mt-8 flex items-center justify-center w-full py-4 rounded-2xl bg-slate-900 text-white text-sm font-bold hover:bg-red-600 border-red-600 border hover:border-slate-900 dark:hover:border-white transition-all"
                >
                    Explore Archive
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="3"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="ml-2 transition-transform group-hover:translate-x-1"
                        ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"
                        ></path></svg
                    >
                </a>
            </SidebarCard>
        </Sidebar>
    </div>

    <!-- Community Creators Section -->
    <div class="mb-20">
        <SectionHeading title="Community Creators" viewAllHref="/creators/1" />
        <div class="flex flex-wrap gap-4 mt-8">
            {channelData.map((channel) => (
                <CreatorPill 
                    label={channel.label}
                    count={channel.videoCount}
                    avatar={channel.avatar}
                    creatorId={channel.creatorId}
                />
            ))}
        </div>
    </div>

    <!-- Ecosystem Pulse -->
    <div class="mb-20">
        <SectionHeading title="Ecosystem Pulse" />
        <Grid columns={2} gap="large">
            <FeatureCard
                title="RFC Tracker"
                description="PHP 8.5 is in active development. Stay updated with the latest language proposals and voting results."
                badge="Development"
                href="/rfcs"
            />
            <FeatureCard
                title="Community Podcasts"
                description="Listen to the experts. We curate the best PHP podcasts to keep you informed on the go."
                badge="Audio"
                href="/podcasts"
            />
        </Grid>
    </div>
</Layout>
