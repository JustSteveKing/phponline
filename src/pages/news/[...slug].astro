---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { BannerCTA } from "@/components";
import { SITE_CONFIG } from "@/config/site";
import { getReadingTime } from "@/utils/readingTime";

export async function getStaticPaths() {
    const news = await getCollection("news");
    return news.map((entry) => ({
        params: { slug: entry.id },
        props: { entry },
    }));
}

interface Props {
    entry: CollectionEntry<"news">;
}

const { entry } = Astro.props;
const { title, link, pubDate, coverImage, content, source, author } =
    entry.data;

const formattedDate = pubDate.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});

const readingTime = getReadingTime(content);
const ogDescription =
    content?.replace(/<\/?[^>]+(>|$)/g, "").substring(0, 160) + "...";

const sd = {
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    "headline": title,
    "image": coverImage ? [coverImage] : [],
    "datePublished": pubDate.toISOString(),
    "author": [{
        "@type": "Person",
        "name": author || source,
        "url": link
    }],
    "publisher": {
        "@type": "Organization",
        "name": "phponline.dev",
        "logo": {
            "@type": "ImageObject",
            "url": "https://www.phponline.dev/favicon.svg"
        }
    }
};

const breadcrumbs = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://www.phponline.dev"
        },
        {
            "@type": "ListItem",
            "position": 2,
            "name": "News",
            "item": "https://www.phponline.dev/archive/1"
        },
        {
            "@type": "ListItem",
            "position": 3,
            "name": title,
            "item": `https://www.phponline.dev/news/${entry.id}`
        }
    ]
};
---

<Layout
    title={`${title} | phponline.dev`}
    description={ogDescription}
    ogImage={`/og/${entry.id}.png`}
    canonical={link}
    sd={[sd, breadcrumbs]}
>
    <article class="max-w-4xl mx-auto py-12 md:py-20">
        <header class="mb-16">
            <div class="flex flex-wrap items-center gap-4 mb-8">
                <span
                    class="px-4 py-1.5 bg-red-600 text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-full shadow-lg shadow-red-500/20"
                >
                    {source}
                </span>
                <div
                    class="flex items-center gap-2 text-slate-900 dark:text-white text-xs font-bold uppercase tracking-widest"
                >
                    <time datetime={pubDate.toISOString()}>
                        {formattedDate}
                    </time>
                    <span>•</span>
                    <span>{readingTime}</span>
                </div>
            </div>

            <h1
                class="text-4xl md:text-6xl font-black text-slate-900 dark:text-white leading-[1.1] tracking-tight mb-10 uppercase"
            >
                {title}
            </h1>

            <div class="flex items-center gap-4 mb-12">
                <div
                    class="w-12 h-12 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-900 dark:text-white"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"
                        ></path><circle cx="12" cy="7" r="4"></circle></svg
                    >
                </div>
                <div>
                    <p class="text-slate-900 dark:text-white font-bold text-sm">
                        {author || source}
                    </p>
                    <p
                        class="text-slate-900 dark:text-white text-xs font-medium"
                    >
                        Contributor at {source}
                    </p>
                </div>
            </div>

            {
                coverImage && (
                    <div class="rounded-3xl overflow-hidden shadow-2xl mb-16 relative group">
                        <img
                            src={coverImage}
                            alt={title}
                            width={1200}
                            height={630}
                            decoding="async"
                            loading="lazy"
                            class="w-full h-auto object-cover aspect-video transition-transform duration-700 group-hover:scale-105"
                        />
                        <div class="absolute inset-0 bg-linear-to-t from-slate-900/20 dark:from-slate-100/20 to-transparent" />
                    </div>
                )
            }
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
            <!-- Sidebar for article info -->
            <aside class="lg:col-span-3 hidden lg:block">
                <div class="sticky top-32 space-y-12">
                    <div>
                        <h4
                            class="text-[10px] font-black text-slate-900 dark:text-white uppercase tracking-[0.2em] mb-4"
                        >
                            Original
                        </h4>
                        <a
                            href={link}
                            target="_blank"
                            class="text-xs font-bold text-red-600 hover:underline break-words block"
                        >
                            {new URL(link || "https://phponline.dev").hostname}
                        </a>
                    </div>
                </div>
            </aside>

            <!-- Main Content -->
            <div class="lg:col-span-9">
                <div
                    class="prose prose-slate dark:prose-invert prose-xl max-w-none mb-20 prose-headings:font-black prose-headings:tracking-tight prose-a:text-red-600 prose-img:rounded-3xl prose-pre:rounded-2xl prose-pre:bg-slate-900 text-slate-900 dark:text-white"
                >
                    <div set:html={content} />
                </div>

                <BannerCTA 
                    title="Read the full story?"
                    description={`This article was originally published on ${source}. Supporting original authors is key to a healthy community.`}
                    buttonText={`Continue on ${source}`}
                    href={link || SITE_CONFIG.links.github}
                    variant="red"
                />
            </div>
        </div>

        <footer
            class="mt-20 pt-12 border-t border-slate-800 dark:border-slate-100 flex flex-col items-center gap-6"
        >
            <a
                href="/archive/1"
                class="group text-slate-900 dark:text-white hover:text-red-600 text-sm font-bold flex items-center gap-2 transition-colors"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="transition-transform group-hover:-translate-x-1"
                    ><path d="m15 18-6-6 6-6"></path></svg
                >
                Back to Archive
            </a>
        </footer>
    </article>
</Layout>
