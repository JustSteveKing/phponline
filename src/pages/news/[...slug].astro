---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { BannerCTA, ArticleHeader, Sidebar, SidebarCard } from "@/components";
import { SITE_CONFIG } from "@/config/site";
import { getReadingTime } from "@/utils/readingTime";

export async function getStaticPaths() {
    const news = await getCollection("news");
    return news.map((entry) => ({
        params: { slug: entry.id },
        props: { entry },
    }));
}

interface Props {
    entry: CollectionEntry<"news">;
}

const { entry } = Astro.props;
const { title, link, pubDate, coverImage, content, source, author, tags } =
    entry.data;

const formattedDate = pubDate.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});

const readingTime = getReadingTime(content);
const ogDescription =
    content?.replace(/<\/?[^>]+(>|$)/g, "").substring(0, 160) + "...";

const sd = {
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    "headline": title,
    "image": coverImage ? [coverImage] : [],
    "datePublished": pubDate.toISOString(),
    "author": [{
        "@type": "Person",
        "name": author || source,
        "url": link
    }],
    "publisher": {
        "@type": "Organization",
        "name": "phponline.dev",
        "logo": {
            "@type": "ImageObject",
            "url": "https://phponline.dev/favicon.svg"
        }
    }
};

const breadcrumbs = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://phponline.dev"
        },
        {
            "@type": "ListItem",
            "position": 2,
            "name": "News",
            "item": "https://phponline.dev/archive/1"
        },
        {
            "@type": "ListItem",
            "position": 3,
            "name": title,
            "item": `https://phponline.dev/news/${entry.id}`
        }
    ]
};
---

<Layout
    title={`${title} | phponline.dev`}
    description={ogDescription}
    ogImage={`/og/${entry.id}.png`}
    canonical={link}
    sd={[sd, breadcrumbs]}
>
    <article class="max-w-4xl mx-auto py-12 md:py-20">
        <ArticleHeader 
            title={title}
            source={source}
            pubDate={pubDate}
            readingTime={readingTime}
            author={author}
            coverImage={coverImage}
            tags={tags}
        />

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
            <!-- Sidebar for article info -->
            <Sidebar colSpan="lg:col-span-3" class="hidden lg:block">
                <SidebarCard title="Original">
                    <a
                        href={link}
                        target="_blank"
                        class="text-xs font-bold text-red-600 hover:underline break-words block"
                    >
                        {new URL(link || "https://phponline.dev").hostname}
                    </a>
                </SidebarCard>
            </Sidebar>

            <!-- Main Content -->
            <div class="lg:col-span-9">
                <div
                    class="prose prose-slate dark:prose-invert prose-xl max-w-none mb-20 prose-headings:font-black prose-headings:tracking-tight prose-a:text-red-600 prose-img:rounded-3xl prose-pre:rounded-2xl prose-pre:bg-slate-900 text-slate-900 dark:text-white"
                >
                    <div set:html={content} />
                </div>

                <BannerCTA 
                    title="Read the full story?"
                    description={`This article was originally published on ${source}. Supporting original authors is key to a healthy community.`}
                    buttonText={`Continue on ${source}`}
                    href={link || SITE_CONFIG.links.github}
                    variant="red"
                />
            </div>
        </div>

        <footer
            class="mt-20 pt-12 border-t border-slate-800 dark:border-slate-100 flex flex-col items-center gap-6"
        >
            <a
                href="/archive/1"
                class="group text-slate-900 dark:text-white hover:text-red-600 text-sm font-bold flex items-center gap-2 transition-colors"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="transition-transform group-hover:-translate-x-1"
                    ><path d="m15 18-6-6 6-6"></path></svg
                >
                Back to Archive
            </a>
        </footer>
    </article>
</Layout>
