---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { NewsCard } from "@/components";
import type { CollectionEntry } from "astro:content";
import type { GetStaticPaths, Page } from "astro";

interface Props {
    page: Page<CollectionEntry<"news">>;
}

export const getStaticPaths = (async ({ paginate }) => {
    const allNews: CollectionEntry<"news">[] = await getCollection("news");
    const sortedNews = allNews.sort(
        (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
    );

    // Split the 700+ items into pages of 24 items each
    return paginate(sortedNews, { pageSize: 24 });
}) satisfies GetStaticPaths;

// All paginated data is passed via the "page" prop
const { page } = Astro.props as Props;
---

<Layout title={`Archive - Page ${page.currentPage} | phponline.dev`}>
    <header class="mb-12 border-b border-slate-100 pb-8">
        <h1 class="text-4xl font-black tracking-tight text-slate-900">
            Community Archive
        </h1>
        <p class="text-slate-500 mt-2">
            Browsing {page.total} curated PHP resources.
        </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
            page.data.map((item) => (
                <div class="border border-slate-100 rounded-2xl p-4 hover:shadow-md transition-shadow">
                    <NewsCard item={item} />
                    <p class="text-xs text-slate-400 mt-3 px-2 line-clamp-3">
                        {item.data.content?.substring(0, 100)}...
                    </p>
                </div>
            ))
        }
    </div>

    <nav class="mt-16 flex items-center justify-center gap-4">
        {
            page.url.prev ? (
                <a
                    href={page.url.prev}
                    class="px-6 py-2 bg-slate-900 text-white rounded-full text-sm font-bold"
                >
                    ← Newer
                </a>
            ) : (
                <span class="px-6 py-2 bg-slate-100 text-slate-400 rounded-full text-sm font-bold cursor-not-allowed">
                    ← Newer
                </span>
            )
        }

        <span class="text-sm font-medium text-slate-500">
            Page {page.currentPage} of {page.lastPage}
        </span>

        {
            page.url.next ? (
                <a
                    href={page.url.next}
                    class="px-6 py-2 bg-slate-900 text-white rounded-full text-sm font-bold"
                >
                    Older →
                </a>
            ) : (
                <span class="px-6 py-2 bg-slate-100 text-slate-400 rounded-full text-sm font-bold cursor-not-allowed">
                    Older →
                </span>
            )
        }
    </nav>
</Layout>
