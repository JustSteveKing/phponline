---
import Layout from "@/layouts/Layout.astro";
import { PageHeader, StatusBadge } from "@/components";
import { getCollection } from "astro:content";

const allNews = await getCollection("news");
// Filter news from the internals source (RFCs)
const rfcItems = allNews
    .filter((item) => item.data.source === "rfc") // Using the label/sourceSlug
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 15);

const breadcrumbs = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.phponline.dev" },
        { "@type": "ListItem", "position": 2, "name": "RFC Tracker", "item": "https://www.phponline.dev/rfcs" }
    ]
};
---

<Layout 
    title="RFC Tracker | phponline.dev"
    description="Monitor the evolution of PHP in real-time. Follow every RFC from discussion to implementation with our community tracker."
    ogImage="/og/rfcs.png"
    sd={[breadcrumbs]}
>
    <PageHeader 
        title="RFC TRACKER" 
        description="Monitoring the evolution of the PHP language. Real-time updates from the Internals mailing list."
        badge="Core Development"
    />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
            rfcItems.map((rfc) => (
                <a 
                    href={`/news/${rfc.id}`}
                    class="flex flex-col h-full bg-white border border-slate-100 rounded-2xl p-8 hover:shadow-2xl hover:-translate-y-2 hover:border-red-100 transition-all duration-500 group"
                >
                    <div class="flex items-center justify-between mb-6">
                        <StatusBadge status={rfc.data.status} />
                        <time class="text-[10px] font-black text-slate-400 uppercase tracking-widest">
                            {rfc.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                        </time>
                    </div>
                    
                    <h3 class="text-xl font-black text-slate-900 mb-4 group-hover:text-red-600 transition-colors leading-tight uppercase">
                        {rfc.data.title.replace(/\[.*\]\s*/, "")}
                    </h3>
                    
                    <p class="text-slate-500 text-sm mb-8 line-clamp-3 font-medium leading-relaxed">
                        {rfc.data.content || "No description available for this RFC proposal."}
                    </p>
                    
                    <div class="mt-auto pt-6 border-t border-slate-50 flex items-center justify-between">
                        <span class="text-[10px] font-black uppercase tracking-widest text-red-600">
                            View Proposal
                        </span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-red-600 transition-transform group-hover:translate-x-1">
                            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                        </svg>
                    </div>
                </a>
            ))
        }
    </div>

    <div class="mt-20 bg-slate-900 rounded-3xl p-12 md:p-20 flex flex-col lg:flex-row items-center justify-between gap-12 relative overflow-hidden">
        <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-red-400 via-transparent to-transparent"></div>
        <div class="relative z-10 max-w-xl">
            <h3 class="text-3xl md:text-4xl font-black text-white mb-6 leading-tight">WANT TO HELP SHAPE PHP?</h3>
            <p class="text-slate-400 text-lg font-medium leading-relaxed">
                The PHP Internals mailing list is where every new feature starts. Join the discussion and help build the future of the web.
            </p>
        </div>
        <a 
            href="https://www.php.net/mailing-lists.php" 
            target="_blank"
            class="relative z-10 whitespace-nowrap bg-red-600 hover:bg-red-700 text-white px-10 py-5 rounded-full font-black text-sm uppercase tracking-widest shadow-2xl shadow-red-500/40 transition-all group"
        >
            Join Internals
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="inline-block ml-2 transition-transform group-hover:translate-x-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
    </div>
</Layout>
