---
import Layout from "@/layouts/Layout.astro";
import { PageHeader, InfoCard } from "@/components";
import CopyHealthData from "@/components/interactive/CopyHealthData.svelte";
import { PHP_STATUS } from "@/config/versions";
import { PAGES } from "@/config/pages";

const breadcrumbs = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://phponline.dev" },
        { "@type": "ListItem", "position": 2, "name": "PHP Health", "item": "https://phponline.dev/health" }
    ]
};

const statusThemes = {
    active: "bg-green-100 text-green-700 border-green-200 dark:bg-green-900/30 dark:text-green-400 dark:border-green-800/50",
    security: "bg-amber-100 text-amber-700 border-amber-200 dark:bg-amber-900/30 dark:text-amber-400 dark:border-amber-800/50",
    eol: "bg-red-100 text-red-700 border-red-200 dark:bg-red-900/30 dark:text-red-400 dark:border-red-800/50",
};
---

<Layout 
    title={PAGES.health.title}
    description={PAGES.health.description}
    ogImage={PAGES.health.ogImage}
    sd={[breadcrumbs]}
>
	<PageHeader
		title="PHP VERSION HEALTH"
		description="A comprehensive guide to the support lifecycle of the PHP language."
        badge="System Status"
	/>

    <div class="mb-20">
        <div class="flex justify-end mb-6">
            <CopyHealthData phpStatus={PHP_STATUS} client:load />
        </div>
        
        <div class="bg-white dark:bg-[#0f172a] border border-slate-100 dark:border-slate-800/50 rounded-2xl overflow-hidden shadow-xl">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50 dark:bg-slate-900/50 border-b border-slate-100 dark:border-slate-800">
                            <th class="px-8 py-6 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400">Version</th>
                            <th class="px-8 py-6 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400">Status</th>
                            <th class="px-8 py-6 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400">Released</th>
                            <th class="px-8 py-6 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400">Active Support Until</th>
                            <th class="px-8 py-6 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400">Security Support Until</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50 dark:divide-slate-800/50">
                        {Object.entries(PHP_STATUS)
                            .sort(([vA], [vB]) => parseFloat(vB) - parseFloat(vA))
                            .map(([version, data]) => (
                            <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-colors">
                                <td class="px-8 py-6">
                                    <span class="text-xl font-black text-slate-900 dark:text-white uppercase tracking-tight">PHP {version}</span>
                                </td>
                                <td class="px-8 py-6">
                                    <span class:list={["px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border", statusThemes[data.status as keyof typeof statusThemes]]}>
                                        {data.status}
                                    </span>
                                </td>
                                <td class="px-8 py-6 text-sm font-bold text-slate-500 dark:text-slate-400 tabular-nums">
                                    {new Date(data.initialRelease).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                                </td>
                                <td class="px-8 py-6 text-sm font-bold text-slate-500 dark:text-slate-400 tabular-nums">
                                    {new Date(data.activeUntil).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                                </td>
                                <td class="px-8 py-6 text-sm font-bold text-slate-500 dark:text-slate-400 tabular-nums">
                                    {new Date(data.securityUntil).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                                </td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <InfoCard 
            variant="green"
            title="Active Support"
            description="A release that is being actively supported. Reported bugs and security issues are fixed and regular point releases are made."
        />
        <InfoCard 
            variant="amber"
            title="Security Only"
            description="A release that is only supported for critical security issues. Releases are only made on an as-needed basis."
        />
        <InfoCard 
            variant="red"
            title="End of Life (EOL)"
            description="A release that is no longer supported. Users of this release should upgrade as soon as possible, as they may be exposed to unpatched security vulnerabilities."
        />
    </div>
</Layout>
