---
import Layout from "@/layouts/Layout.astro";
import { PageHeader, Grid, FeatureCard, BannerCTA } from "@/components";
import { PODCAST_FEEDS } from "@/config/feeds";
import { SITE_CONFIG } from "@/config/site";
import { getCollection } from "astro:content";
import { slugify } from "@/utils/slugify";

const episodes = await getCollection("episodes");

const podcastData = PODCAST_FEEDS.map((podcast) => {
    const podcastEpisodes = episodes.filter(e => e.data.podcast === podcast.title);
    return {
        ...podcast,
        episodeCount: podcastEpisodes.length,
        slug: slugify(podcast.title)
    };
});

const breadcrumbs = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://phponline.dev" },
        { "@type": "ListItem", "position": 2, "name": "Podcasts", "item": "https://phponline.dev/podcasts" }
    ]
};
---

<Layout 
    title="PHP Podcasts | phponline.dev"
    description="Tune in to the voices shaping the ecosystem. A curated directory of the best PHP podcasts for developers."
    ogImage="/og/podcasts.png"
    sd={[breadcrumbs]}
>
	<PageHeader
		title="COMMUNITY PODCASTS"
		description="Tune in to the voices shaping the ecosystem. Curated shows from the best in the PHP world."
        badge="Audio Directory"
	/>

	<Grid columns={3} gap="large">
		{podcastData.map((podcast) => (
			<FeatureCard 
                title={podcast.title}
                description={`${podcast.description} (${podcast.episodeCount} episodes)`}
                badge={podcast.badge}
                href={`/podcasts/${podcast.slug}`}
            />
		))}
	</Grid>

	<BannerCTA 
        title="Host a Podcast?"
        description="We're always looking to expand our directory. If you run a PHP-focused podcast, let us know so we can add you to the feed and help you reach more listeners."
        buttonText="Submit your Podcast"
        href={SITE_CONFIG.links.github}
        variant="red"
    />
</Layout>
