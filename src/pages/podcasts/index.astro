---
import Layout from "@/layouts/Layout.astro";
import { PageHeader, Grid, FeatureCard } from "@/components";

const podcastFeeds = [
	{
		title: "The PHP Podcast",
		description: "Stay up to date with the latest PHP news, releases, and community discussions. Hosted by Eric Van Johnson and John Congdon.",
		href: "https://www.phproundtable.com/",
		badge: "Weekly Show",
	},
	{
		title: "PHP Ugly",
		description: "The casual, often humorous side of the PHP community. Weekly discussions on the industry from a developer's perspective.",
		href: "https://phpugly.com/",
		badge: "Entertainment",
	},
	{
		title: "Voices of the Elephant",
		description: "Short, snackable interviews with the most interesting people in the PHP community. A long-running community staple.",
		href: "https://voicesoftheelephant.com/",
		badge: "Interviews",
	},
    {
		title: "The Laravel Podcast",
		description: "The definitive Laravel podcast. Matt Stauffer and friends discuss everything happening in the Laravel ecosystem.",
		href: "https://laravelpodcast.com/",
		badge: "Framework Focus",
	},
    {
		title: "No Plans to Merge",
		description: "A casual chat about developer life, PHP, and the business of building software. Hosted by Caleb Porzio and Daniel Coulbourne.",
		href: "https://noplanstomerge.com/",
		badge: "Developer Life",
	},
    {
		title: "NorthMeetSouth",
		description: "A show about the PHP community, parenting, and everything in between. Hosted by Jacob Bennett and Michael Dyrynda.",
		href: "https://northmeetsouth.audio/",
		badge: "Casual Chat",
	}
];

const breadcrumbs = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.phponline.dev" },
        { "@type": "ListItem", "position": 2, "name": "Podcasts", "item": "https://www.phponline.dev/podcasts" }
    ]
};
---

<Layout 
    title="PHP Podcasts | phponline.dev"
    description="Tune in to the voices shaping the ecosystem. A curated directory of the best PHP podcasts for developers."
    ogImage="/og/podcasts.png"
    sd={[breadcrumbs]}
>
	<PageHeader
		title="COMMUNITY PODCASTS"
		description="Tune in to the voices shaping the ecosystem. Curated shows from the best in the PHP world."
        badge="Audio Directory"
	/>

	<Grid columns={3} gap="large">
		{podcastFeeds.map((podcast) => (
			<FeatureCard {...podcast} />
		))}
	</Grid>

	<div class="mt-32 bg-red-600 rounded-[40px] p-12 md:p-20 text-center text-white relative overflow-hidden shadow-2xl shadow-red-200">
		<div class="absolute inset-0 opacity-10 pointer-events-none">
            <div class="absolute -top-24 -left-24 w-96 h-96 bg-white rounded-full blur-3xl"></div>
        </div>
        
        <div class="relative z-10 max-w-2xl mx-auto">
            <h3 class="text-3xl md:text-5xl font-black mb-6 tracking-tight uppercase">Host a Podcast?</h3>
            <p class="text-red-100 text-lg mb-10 font-medium leading-relaxed">
                We're always looking to expand our directory. If you run a PHP-focused podcast,
                let us know so we can add you to the feed and help you reach more listeners.
            </p>
            <button class="bg-white text-red-600 px-12 py-5 rounded-full font-black uppercase tracking-widest text-sm hover:bg-red-50 transition-all shadow-xl">
                Submit your Podcast
            </button>
        </div>
	</div>
</Layout>
