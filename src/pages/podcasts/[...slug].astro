---
import Layout from "@/layouts/Layout.astro";
import { PageHeader, Grid, FeatureCard } from "@/components";
import PlayButton from "@/components/interactive/PlayButton.svelte";
import { PODCAST_FEEDS } from "@/config/feeds";
import { getCollection } from "astro:content";
import { slugify } from "@/utils/slugify";

export async function getStaticPaths() {
    const episodes = await getCollection("episodes");

    return PODCAST_FEEDS.map((podcast) => {
        const podcastEpisodes = episodes
            .filter((e) => e.data.podcast === podcast.title)
            .sort(
                (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
            );

        return {
            params: { slug: slugify(podcast.title) },
            props: { podcast, episodes: podcastEpisodes },
        };
    });
}

const { podcast, episodes } = Astro.props;
const slug = slugify(podcast.title);
const ogImage = `/og/podcasts/${slug}.png`;

const podcastSeries = {
    "@context": "https://schema.org",
    "@type": "PodcastSeries",
    name: podcast.title,
    description: podcast.description,
    url: `https://www.phponline.dev/podcasts/${slug}`,
    webFeed: podcast.feed,
};

const breadcrumbs = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
        {
            "@type": "ListItem",
            position: 1,
            name: "Home",
            item: "https://www.phponline.dev",
        },
        {
            "@type": "ListItem",
            position: 2,
            name: "Podcasts",
            item: "https://www.phponline.dev/podcasts",
        },
        {
            "@type": "ListItem",
            position: 3,
            name: podcast.title,
            item: `https://www.phponline.dev/podcasts/${slugify(podcast.title)}`,
        },
    ],
};
---

<Layout 
    title={`${podcast.title} | PHP Podcasts`}
    description={podcast.description}
    ogImage={ogImage}
    sd={[breadcrumbs, podcastSeries]}
>    <PageHeader
        title={podcast.title}
        description={podcast.description}
        badge={podcast.badge}
    />

    <div class="mb-12">
        <a
            href={podcast.href}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-6 py-3 bg-slate-900 text-white rounded-full font-bold text-sm uppercase tracking-widest hover:bg-red-600 transition-colors"
        >
            Visit Official Website
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="ml-2"
                ><path
                    d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"
                ></path><polyline points="15 3 21 3 21 9"></polyline><line
                    x1="10"
                    y1="14"
                    x2="21"
                    y2="3"></line></svg
            >
        </a>
    </div>

    <div class="space-y-8">
        <h2
            class="text-3xl font-black text-slate-900 dark:text-white uppercase tracking-tight"
        >
            Latest Episodes
        </h2>

        <div class="grid grid-cols-1 gap-6">
            {
                episodes.map((episode) => (
                    <div class="bg-white dark:bg-[#0f172a] border border-slate-100 dark:border-slate-800/50 rounded-2xl p-8 hover:shadow-xl transition-all duration-300 group">
                        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
                            <div class="flex-1">
                                <div class="flex items-center gap-3 mb-4">
                                    <span class="text-[10px] font-black uppercase tracking-widest text-red-600 bg-red-50 px-2 py-1 rounded">
                                        {new Date(
                                            episode.data.pubDate,
                                        ).toLocaleDateString("en-US", {
                                            month: "short",
                                            day: "numeric",
                                            year: "numeric",
                                        })}
                                    </span>
                                    {episode.data.duration && (
                                        <span class="text-[10px] font-black uppercase tracking-widest text-slate-500 bg-slate-50 px-2 py-1 rounded">
                                            {episode.data.duration}
                                        </span>
                                    )}
                                    {episode.data.episode && (
                                        <span class="text-[10px] font-black uppercase tracking-widest text-slate-500 bg-slate-50 px-2 py-1 rounded">
                                            Ep. {episode.data.episode}
                                        </span>
                                    )}
                                </div>
                                <h3 class="text-xl font-black text-slate-900 dark:text-white mb-3 group-hover:text-red-600 transition-colors">
                                    {episode.data.title}
                                </h3>
                                <div
                                    class="text-slate-500 dark:text-slate-400 text-sm line-clamp-2 mb-4 font-medium"
                                    set:html={episode.data.content}
                                />
                            </div>

                            <div class="flex items-center gap-4">
                                {episode.data.audioUrl && (
                                    <PlayButton
                                        client:load
                                        title={episode.data.title}
                                        podcast={episode.data.podcast}
                                        audioUrl={episode.data.audioUrl}
                                    />
                                )}
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</Layout>
