---
import Layout from "@/layouts/Layout.astro";
import { PageHeader, EpisodeCard, SectionHeading } from "@/components";
import { PODCAST_FEEDS } from "@/config/feeds";
import { getCollection, type CollectionEntry } from "astro:content";
import { slugify } from "@/utils/slugify";

export async function getStaticPaths() {
    const episodes: CollectionEntry<"episodes">[] = await getCollection("episodes");

    return PODCAST_FEEDS.map((podcast) => {
        const podcastEpisodes = episodes
            .filter((e: CollectionEntry<"episodes">) => e.data.podcast === podcast.title)
            .sort(
                (a: CollectionEntry<"episodes">, b: CollectionEntry<"episodes">) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
            );

        return {
            params: { slug: slugify(podcast.title) },
            props: { podcast, episodes: podcastEpisodes },
        };
    });
}

const { podcast, episodes } = Astro.props as { podcast: any, episodes: CollectionEntry<"episodes">[] };
const slug = slugify(podcast.title);
const ogImage = `/og/podcasts/${slug}.png`;

const podcastSeries = {
    "@context": "https://schema.org",
    "@type": "PodcastSeries",
    name: podcast.title,
    description: podcast.description,
    url: `https://phponline.dev/podcasts/${slug}`,
    webFeed: podcast.feed,
};

const breadcrumbs = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
        {
            "@type": "ListItem",
            position: 1,
            name: "Home",
            item: "https://phponline.dev",
        },
        {
            "@type": "ListItem",
            position: 2,
            name: "Podcasts",
            item: "https://phponline.dev/podcasts",
        },
        {
            "@type": "ListItem",
            position: 3,
            name: podcast.title,
            item: `https://phponline.dev/podcasts/${slugify(podcast.title)}`,
        },
    ],
};
---

<Layout 
    title={`${podcast.title} | PHP Podcasts`}
    description={podcast.description}
    ogImage={ogImage}
    sd={[breadcrumbs, podcastSeries]}
>    <PageHeader
        title={podcast.title}
        description={podcast.description}
        badge={podcast.badge}
    />

    <div class="mb-12">
        <a
            href={podcast.href}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-6 py-3 bg-slate-900 text-white rounded-full font-bold text-sm uppercase tracking-widest hover:bg-red-600 transition-colors"
        >
            Visit Official Website
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="ml-2"
                ><path
                    d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"
                ></path><polyline points="15 3 21 3 21 9"></polyline><line
                    x1="10"
                    y1="14"
                    x2="21"
                    y2="3"></line></svg
            >
        </a>
    </div>

    <div class="space-y-8">
        <SectionHeading title="Latest Episodes" />

        <div class="grid grid-cols-1 gap-6">
            {
                episodes.map((episode) => (
                    <EpisodeCard episode={episode} />
                ))
            }
        </div>
    </div>
</Layout>
