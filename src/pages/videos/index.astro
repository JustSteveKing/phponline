---
import Layout from "@/layouts/Layout.astro";
import { PageHeader, Grid, VideoCard, CreatorPill, BannerCTA, SectionHeading } from "@/components";
import { YOUTUBE_CHANNELS } from "@/config/feeds";
import { SITE_CONFIG } from "@/config/site";
import { PAGES } from "@/config/pages";
import { getCollection, type CollectionEntry } from "astro:content";
import { slugify } from "@/utils/slugify";
import type { YouTubeChannel } from "@/types";

const allVideos = await getCollection("videos");
const sortedVideos = allVideos.sort((a: CollectionEntry<"videos">, b: CollectionEntry<"videos">) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latestVideos = sortedVideos.slice(0, 12);

const channelData = YOUTUBE_CHANNELS.map((channel: YouTubeChannel) => {
    const videoCount = allVideos.filter((v: CollectionEntry<"videos">) => v.data.channel === channel.label).length;
    return {
        ...channel,
        videoCount,
        slug: slugify(channel.label)
    };
});

const breadcrumbs = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://phponline.dev" },
        { "@type": "ListItem", "position": 2, "name": "Videos", "item": "https://phponline.dev/videos" }
    ]
};
---

<Layout 
    title={PAGES.videos.title}
    description={PAGES.videos.description}
    ogImage={PAGES.videos.ogImage}
    sd={[breadcrumbs]}
>
	<PageHeader
		title="COMMUNITY VIDEOS"
		description="Learn from the best in the PHP ecosystem. High-quality tutorials and updates from top YouTube creators."
        badge="Video Directory"
	/>

    <div class="mb-20">
        <SectionHeading title="Featured Creators" />
        <div class="flex flex-wrap justify-center gap-4 max-w-5xl mx-auto mt-8">
            {channelData.map((channel: any) => (
                <CreatorPill 
                    label={channel.label}
                    count={channel.videoCount}
                    avatar={channel.avatar}
                    creatorId={channel.creatorId}
                />
            ))}
        </div>
    </div>

    <div class="space-y-8">
        <SectionHeading title="Latest Uploads" />
        <Grid columns={3} gap="large">
            {latestVideos.map((video: CollectionEntry<"videos">) => (
                <VideoCard video={video} />
            ))}
        </Grid>
    </div>

	<BannerCTA 
        title="Are you a creator?"
        description="If you run a PHP or Laravel-focused YouTube channel, we want to hear from you. Let us know so we can add your feed to our directory."
        buttonText="Submit your Channel"
        href={SITE_CONFIG.links.github}
    />
</Layout>
