---
import Layout from "@/layouts/Layout.astro";
import { PageHeader, Grid, VideoCard, CreatorPill, BannerCTA } from "@/components";
import { YOUTUBE_CHANNELS } from "@/config/feeds";
import { SITE_CONFIG } from "@/config/site";
import { getCollection } from "astro:content";
import { slugify } from "@/utils/slugify";

const allVideos = await getCollection("videos");
const sortedVideos = allVideos.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latestVideos = sortedVideos.slice(0, 12);

const channelData = YOUTUBE_CHANNELS.map((channel) => {
    const videoCount = allVideos.filter(v => v.data.channel === channel.label).length;
    return {
        ...channel,
        videoCount,
        slug: slugify(channel.label)
    };
});

const breadcrumbs = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.phponline.dev" },
        { "@type": "ListItem", "position": 2, "name": "Videos", "item": "https://www.phponline.dev/videos" }
    ]
};
---

<Layout 
    title="PHP Videos & Tutorials | phponline.dev"
    description="Watch the latest PHP and Laravel tutorials from the community's top creators. Curated videos for modern developers."
    ogImage="/og/home.png"
    sd={[breadcrumbs]}
>
	<PageHeader
		title="COMMUNITY VIDEOS"
		description="Learn from the best in the PHP ecosystem. High-quality tutorials and updates from top YouTube creators."
        badge="Video Directory"
	/>

    <div class="mb-20">
        <h2 class="text-3xl font-black text-slate-900 dark:text-white uppercase tracking-tight mb-10 text-center">Featured Creators</h2>
        <div class="flex flex-wrap justify-center gap-4 max-w-5xl mx-auto">
            {channelData.map((channel) => (
                <CreatorPill 
                    label={channel.label}
                    count={channel.videoCount}
                    avatar={channel.avatar}
                />
            ))}
        </div>
    </div>

    <div class="space-y-8">
        <h2 class="text-3xl font-black text-slate-900 dark:text-white uppercase tracking-tight">Latest Uploads</h2>
        <Grid columns={3} gap="large">
            {latestVideos.map((video) => (
                <VideoCard video={video} />
            ))}
        </Grid>
    </div>

	<BannerCTA 
        title="Are you a creator?"
        description="If you run a PHP or Laravel-focused YouTube channel, we want to hear from you. Let us know so we can add your feed to our directory."
        buttonText="Submit your Channel"
        href={SITE_CONFIG.links.github}
    />
</Layout>
