---
import Layout from "@/layouts/Layout.astro";
import { PageHeader, Grid, VideoCard } from "@/components";
import { YOUTUBE_CHANNELS } from "@/config/feeds";
import { getCollection, type CollectionEntry } from "astro:content";
import { slugify } from "@/utils/slugify";
import type { YouTubeChannel } from "@/types";

export async function getStaticPaths() {
    const allVideos: CollectionEntry<"videos">[] = await getCollection("videos");

    return YOUTUBE_CHANNELS.map((channel: YouTubeChannel) => {
        const channelVideos = allVideos
            .filter((v: CollectionEntry<"videos">) => v.data.channel === channel.label)
            .sort((a: CollectionEntry<"videos">, b: CollectionEntry<"videos">) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

        return {
            params: { slug: slugify(channel.label) },
            props: { channel, videos: channelVideos },
        };
    });
}

const { channel, videos } = Astro.props as { channel: YouTubeChannel, videos: CollectionEntry<"videos">[] };

const breadcrumbs = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://phponline.dev" },
        { "@type": "ListItem", "position": 2, "name": "Videos", "item": "https://phponline.dev/videos" },
        { "@type": "ListItem", "position": 3, "name": channel.label, "item": `https://phponline.dev/videos/${slugify(channel.label)}` }
    ]
};
---

<Layout
    title={`${channel.label} Videos | phponline.dev`}
    description={`Watch the latest tutorials and updates from the ${channel.label} YouTube channel. Curated for PHP developers.`}
    sd={[breadcrumbs]}
>
	<PageHeader
		title={channel.label}
		description={`High-quality video content from ${channel.label}. Stay updated with the latest tutorials and discussions.`}
        badge="YouTube Creator"
	/>

    <div class="mb-12">
        <a
            href={`https://www.youtube.com/channel/${channel.id}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-6 py-3 bg-red-600 text-white rounded-full font-bold text-sm uppercase tracking-widest hover:bg-red-700 transition-colors"
        >
            Subscribe on YouTube
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
        </a>
    </div>

    <div class="space-y-8">
        <h2 class="text-3xl font-black text-slate-900 dark:text-white uppercase tracking-tight">Recent Videos</h2>
        <Grid columns={3} gap="large">
            {videos.map((video: CollectionEntry<"videos">) => (
                <VideoCard video={video} />
            ))}
        </Grid>
    </div>
</Layout>
