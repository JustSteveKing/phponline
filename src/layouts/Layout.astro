---
import "@/styles/main.css";
import { ClientRouter } from "astro:transitions";
import { Footer, Navigation } from "@/components";
import Player from "@/components/interactive/Player.svelte";
import { PAGES } from "@/config/pages";

interface Props {
    title?: string;
    description?: string;
    ogImage?: string;
    canonical?: string;
    sd?: object;
}

const { 
    title = PAGES.home.title, 
    description = PAGES.home.description,
    ogImage = PAGES.home.ogImage,
    canonical,
    sd
} = Astro.props;

const siteUrl = "https://phponline.dev";
const resolvedOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
const sdArray = Array.isArray(sd) ? sd : sd ? [sd] : [];
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        
        {canonical && <link rel="canonical" href={canonical} />}
        
        <!-- Primary Meta Tags -->
        <title>{title}</title>
        <meta name="title" content={title} />
        <meta name="description" content={description} />

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={Astro.url} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={resolvedOgImage} />

        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={Astro.url} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={resolvedOgImage} />

        {
            sdArray.map((data) => (
                <script is:inline type="application/ld+json" set:html={JSON.stringify(data)} />
            ))
        }
        <ClientRouter />
        <script is:inline>
            const getTheme = () => {
                if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
                    return localStorage.getItem('theme');
                }
                return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            };
            const theme = getTheme();
            if (theme === 'dark') {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        </script>
    </head>
    <body class="bg-slate-50 dark:bg-[#020617] text-slate-900 dark:text-slate-300 antialiased selection:bg-red-200 selection:text-red-900 flex flex-col min-h-screen transition-colors duration-500">
        <a 
            href="#main-content" 
            class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-6 focus:py-3 focus:bg-red-600 focus:text-white focus:rounded-full focus:font-black focus:text-sm focus:uppercase focus:tracking-widest focus:shadow-2xl"
        >
            Skip to content
        </a>
        <Navigation />
        <main id="main-content" data-pagefind-body class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 w-full outline-hidden">
            <slot />
        </main>
        <Footer />
        <Player client:load />

        <!-- Cloudflare Web Analytics -->
        <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "d263349729c84ef79b33b723f19eb624"}'></script>
        <!-- End Cloudflare Web Analytics -->
    </body>
</html>
