---
import { Logo } from "../ui";

const currentYear = new Date().getFullYear();

const footerLinks = [
    {
        title: "Community",
        links: [
            { name: "The Pulse", href: "/" },
            { name: "Archive", href: "/archive/1" },
            { name: "RFC Tracker", href: "/rfcs" },
            { name: "Podcasts", href: "/podcasts" },
        ],
    },
    {
        title: "Ecosystem",
        links: [
            { name: "PHP.net", href: "https://php.net" },
            { name: "Laravel News", href: "https://laravel-news.com" },
            { name: "Symfony", href: "https://symfony.com" },
            { name: "PHP Arch", href: "https://phparch.com" },
        ],
    },
    {
        title: "Project",
        links: [
            { name: "About", href: "/about" },
            {
                name: "Submit a Link",
                href: "https://github.com/juststeveking/phponline",
            },
            {
                name: "GitHub",
                href: "https://github.com/juststeveking/phponline",
            },
            { name: "RSS Feed", href: "/rss.xml" },
        ],
    },
];
---

<footer
    class="mt-32 border-t border-slate-900 dark:border-white bg-white dark:bg-slate-900 pt-16 pb-8"
>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12 lg:gap-8 mb-16"
        >
            <div class="lg:col-span-2">
                <a href="/" class="group flex items-center gap-2 mb-6">
                    <Logo class="h-8 w-auto" />
                </a>
                <p
                    class="text-slate-900 dark:text-white font-medium leading-relaxed max-w-sm mb-6"
                >
                    The modern homepage for the PHP community. Aggregating the
                    best news, RFCs, podcasts, and articles from across the
                    ecosystem.
                </p>
                <div class="flex items-center gap-4">
                    <span class="flex h-3 w-3 relative">
                        <span
                            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"
                        ></span>
                        <span
                            class="relative inline-flex rounded-full h-3 w-3 bg-green-500"
                        ></span>
                    </span>
                    <span
                        class="text-xs font-bold text-slate-900 dark:text-white uppercase tracking-widest"
                        >Systems Operational</span
                    >
                </div>
            </div>

            {
                footerLinks.map((column) => (
                    <div>
                        <h3 class="font-black text-slate-900 dark:text-white uppercase tracking-widest text-xs mb-6">
                            {column.title}
                        </h3>
                        <ul class="space-y-4">
                            {column.links.map((link) => (
                                <li>
                                    <a
                                        href={link.href}
                                        class="text-sm font-medium text-slate-900 dark:text-white hover:text-red-600 transition-colors"
                                    >
                                        {link.name}
                                    </a>
                                </li>
                            ))}
                        </ul>
                    </div>
                ))
            }
        </div>

        <div
            class="pt-8 border-t border-slate-900 dark:border-slate-100 flex flex-col md:flex-row items-center justify-between gap-4"
        >
            <p class="text-slate-900 dark:text-white text-sm font-medium">
                &copy; {currentYear} PHP Online. An open source community project.
            </p>
            <div class="flex items-center gap-6">
                <a
                    href="https://github.com/juststeveking/phponline"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-slate-900 dark:text-white hover:text-red-600 transition-colors"
                    aria-label="Visit PHP Online on GitHub"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path
                            d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
                        ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
                    >
                </a>
                <a
                    href="https://x.com/juststeveking"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-slate-900 dark:text-white hover:text-red-600 transition-colors"
                    aria-label="Follow Steve McDougall on X (formerly Twitter)"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path
                            d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"
                        ></path></svg
                    >
                </a>
            </div>
        </div>
    </div>
</footer>
