---
import { Search } from "../interactive";

const navItems = [
    { name: "The Pulse", href: "/" },
    { name: "Archive", href: "/archive/1" },
    { name: "RFC Tracker", href: "/rfcs" }, // Future Phase
    { name: "Podcasts", href: "/podcasts" }, // Future Phase
];

const currentPath = Astro.url.pathname;
---

<nav
    class="sticky top-0 z-50 w-full border-b border-slate-200/60 bg-white/80 backdrop-blur-md"
>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
            <div class="flex items-center gap-2">
                <a href="/" class="group flex items-center gap-2">
                    <div
                        class="bg-blue-600 text-white p-1.5 rounded-lg group-hover:rotate-12 transition-transform"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"
                            ></path></svg
                        >
                    </div>
                    <span
                        class="font-black text-xl tracking-tighter text-slate-900 uppercase"
                    >
                        php<span class="text-blue-600">online</span>
                    </span>
                </a>
            </div>

            <div class="hidden md:flex items-center gap-8">
                {
                    navItems.map((item) => (
                        <a
                            href={item.href}
                            class={`text-sm font-bold transition-colors ${
                                currentPath === item.href ||
                                (currentPath.startsWith(item.href) &&
                                    item.href !== "/")
                                    ? "text-blue-600"
                                    : "text-slate-500 hover:text-slate-900"
                            }`}
                        >
                            {item.name}
                        </a>
                    ))
                }
            </div>

            <div class="flex items-center gap-4">
                <Search client:load />

                <a
                    href="https://github.com/your-username/phponline"
                    target="_blank"
                    class="bg-slate-900 text-white px-4 py-2 rounded-full text-xs font-bold hover:bg-slate-800 transition-all"
                >
                    Submit Link
                </a>
            </div>
        </div>
    </div>
</nav>
