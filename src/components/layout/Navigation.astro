---
import { Logo } from "../ui";
import NavDropdown from "./NavDropdown.svelte";

const navGroups = [
    {
        name: "Community",
        items: [
            { name: "RFCs", href: "/rfcs" },
            { name: "Events", href: "/events" },
        ]
    },
    {
        name: "Library",
        items: [
            { name: "Archive", href: "/archive/1" },
            { name: "Podcasts", href: "/podcasts" },
            { name: "Videos", href: "/videos" },
        ]
    },
];

const currentPath = Astro.url.pathname;

// JSON-LD for Site Navigation
const siteUrl = "https://phponline.dev";
const flatItems = [
    { name: "The Pulse", href: "/" },
    { name: "Creators", href: "/creators/1" },
    ...navGroups.flatMap(g => g.items)
];

const navigationSchema = {
    "@context": "https://schema.org",
    "@type": "ItemList",
    itemListElement: flatItems.map((item, index) => ({
        "@type": "SiteNavigationElement",
        position: index + 1,
        name: item.name,
        url: `${siteUrl}${item.href}`,
    })),
};
---

<script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(navigationSchema)}
/>

<nav
    class="sticky top-0 z-[200] w-full border-b border-slate-100 dark:border-slate-800 bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl shadow-sm transition-colors duration-300"
    id="main-nav"
>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-[210]">
        <div class="flex justify-between h-20 items-center">
            <div class="flex items-center gap-2">
                <a
                    href="/"
                    class="group flex items-center gap-2 transition-transform hover:scale-105"
                >
                    <Logo class="h-8 w-auto text-slate-900 dark:text-white" />
                </a>
            </div>

            <!-- Desktop Menu -->
            <div class="hidden lg:flex items-center gap-8">
                <a
                    href="/"
                    class:list={[
                        "text-sm font-bold transition-all relative py-2",
                        currentPath === "/"
                            ? "text-red-600 after:absolute after:bottom-0 after:left-0 after:w-full after:h-1 after:bg-red-600 after:rounded-t-full"
                            : "text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white",
                    ]}
                >
                    The Pulse
                </a>

                <a
                    href="/creators/1"
                    class:list={[
                        "text-sm font-bold transition-all relative py-2",
                        currentPath.startsWith("/creators")
                            ? "text-red-600 after:absolute after:bottom-0 after:left-0 after:w-full after:h-1 after:bg-red-600 after:rounded-t-full"
                            : "text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white",
                    ]}
                >
                    Creators
                </a>

                {
                    navGroups.map((group) => (
                        <NavDropdown
                            client:load
                            label={group.name}
                            items={group.items}
                            currentPath={currentPath}
                        />
                    ))
                }
            </div>

            <div class="flex items-center gap-4">
                <!-- Search Trigger -->
                <button
                    id="search-trigger"
                    class="flex items-center gap-3 px-4 py-2 rounded-xl bg-slate-100 dark:bg-[#0f172a] text-slate-500 dark:text-slate-400 border border-slate-200/60 dark:border-slate-800/50 hover:border-red-200 dark:hover:border-red-900/30 transition-all group"
                    aria-label="Search content"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-red-600 transition-colors"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    <span class="hidden sm:inline text-xs font-black uppercase tracking-widest group-hover:text-red-600 transition-colors">Search</span>
                    <div class="hidden md:flex items-center gap-1.5 ml-2 px-1.5 py-0.5 bg-white dark:bg-slate-800 rounded border border-slate-200 dark:border-slate-700">
                        <span class="text-[10px] font-black text-slate-400">⌘K</span>
                    </div>
                </button>

                <!-- Mobile Menu Button -->
                <button
                    id="mobile-menu-button"
                    class="lg:hidden p-2 rounded-xl bg-slate-100 dark:bg-[#0f172a] text-slate-600 dark:text-slate-400 border border-slate-200/60 dark:border-slate-800/50"
                    aria-label="Toggle Menu"
                    aria-expanded="false"
                    aria-controls="mobile-menu"
                >
                    <svg
                        id="menu-icon"
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><line x1="4" x2="20" y1="12" y2="12"></line><line
                            x1="4"
                            x2="20"
                            y1="6"
                            y2="6"></line><line x1="4" x2="20" y1="18" y2="18"
                        ></line></svg
                    >
                    <svg
                        id="close-icon"
                        class="hidden"
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path d="M18 6 6 18"></path><path d="m6 6 12 12"
                        ></path></svg
                    >
                </button>
            </div>
        </div>
    </div>

</nav>

<!-- Full Screen Mobile Menu Overlay -->
<div
    id="mobile-menu"
    class="fixed inset-0 z-[150] bg-white dark:bg-slate-900 pt-20 pb-12 px-6 overflow-y-auto transition-all duration-500 ease-in-out opacity-0 pointer-events-none translate-y-10"
    aria-hidden="true"
>
    <div class="max-w-7xl mx-auto space-y-10 z-[160] py-10">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-10">
                <div class="space-y-4">
                    <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">
                        Quick Links
                    </h3>
                    <div class="space-y-2">
                        <a
                            href="/"
                            class:list={[
                                "block px-6 py-5 rounded-3xl text-xl font-black transition-all",
                                currentPath === "/"
                                    ? "bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-500"
                                    : "text-slate-900 dark:text-white hover:bg-slate-50 dark:hover:bg-slate-800",
                            ]}
                        >
                            The Pulse
                        </a>
                        <a
                            href="/creators/1"
                            class:list={[
                                "block px-6 py-5 rounded-3xl text-xl font-black transition-all",
                                currentPath.startsWith("/creators")
                                    ? "bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-500"
                                    : "text-slate-900 dark:text-white hover:bg-slate-50 dark:hover:bg-slate-800",
                            ]}
                        >
                            Creators
                        </a>
                    </div>
                </div>

                {
                    navGroups.map((group) => (
                        <div class="space-y-4">
                            <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">
                                {group.name}
                            </h3>
                            <div class="space-y-2">
                                {group.items.map((item) => (
                                    <a
                                        href={item.href}
                                        class:list={[
                                            "block px-6 py-5 rounded-3xl text-xl font-black transition-all",
                                            currentPath === item.href ||
                                            (currentPath.startsWith(item.href) &&
                                                item.href !== "/")
                                                ? "bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-500"
                                                : "text-slate-900 dark:text-white hover:bg-slate-50 dark:hover:bg-slate-800",
                                        ]}
                                    >
                                        {item.name}
                                    </a>
                                ))}
                            </div>
                        </div>
                    ))
                }
            </div>

            <div class="pt-10 border-t border-slate-100 dark:border-slate-800">
                <p class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-6 px-6">
                    Aggregation site for the PHP community. Aggregating the best news, RFCs, podcasts, and articles.
                </p>
                <div class="flex items-center gap-6 px-6">
                    <a href="https://github.com/juststeveking/phponline" class="text-slate-900 dark:text-white hover:text-red-600 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
                    </a>
                    <a href="https://x.com/juststeveking" class="text-slate-900 dark:text-white hover:text-red-600 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path></svg>
                    </a>
                </div>
            </div>
        </div>
    </div>
</nav>

<style>
    :global(body.menu-open) {
        overflow: hidden;
    }
</style>

<script>
    function setupNavigation() {
        const mobileButton = document.getElementById("mobile-menu-button");
        const searchButton = document.getElementById("search-trigger");
        const menu = document.getElementById("mobile-menu");
        const menuIcon = document.getElementById("menu-icon");
        const closeIcon = document.getElementById("close-icon");

        if (searchButton) {
            searchButton.addEventListener("click", () => {
                window.dispatchEvent(new CustomEvent("open-search"));
                // Close mobile menu if searching
                if (menu && menu.classList.contains("opacity-100")) {
                    toggleMenu();
                }
            });
        }

        if (!mobileButton || !menu) return;

        function toggleMenu() {
            const isOpen = menu.classList.contains("opacity-100");

            if (!isOpen) {
                menu.classList.remove("opacity-0", "pointer-events-none", "translate-y-10");
                menu.classList.add("opacity-100", "pointer-events-auto", "translate-y-0");
                menu.setAttribute("aria-hidden", "false");
                menuIcon?.classList.add("hidden");
                closeIcon?.classList.remove("hidden");
                mobileButton?.setAttribute("aria-expanded", "true");
                document.body.classList.add("menu-open");
            } else {
                menu.classList.remove("opacity-100", "pointer-events-auto", "translate-y-0");
                menu.classList.add("opacity-0", "pointer-events-none", "translate-y-10");
                menu.setAttribute("aria-hidden", "true");
                menuIcon?.classList.remove("hidden");
                closeIcon?.classList.add("hidden");
                mobileButton?.setAttribute("aria-expanded", "false");
                document.body.classList.remove("menu-open");
            }
        }

        mobileButton.addEventListener("click", toggleMenu);

        // Close menu when a link is clicked (important for View Transitions)
        const links = menu.querySelectorAll("a");
        links.forEach((link) => {
            link.addEventListener("click", () => {
                if (menu.classList.contains("opacity-100")) {
                    toggleMenu();
                }
            });
        });
    }

    // Initialize on page load
    setupNavigation();

    // Re-initialize after Astro view transitions
    document.addEventListener("astro:after-swap", setupNavigation);
</script>
