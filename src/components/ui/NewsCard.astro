---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import defaultCover from "@/assets/default-php-cover.png";

import { getTopicLabel } from "@/utils/extractTags";

interface Props {
    item: CollectionEntry<"news">;
}

const { item } = Astro.props as Props;
const { title, source, pubDate, coverImage, tags = [] } = item.data;

const formattedDate = pubDate.toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
});
---

<a
    href={`/news/${item.id}`}
    class="group flex items-center gap-4 p-2 -mx-2 rounded-2xl hover:bg-white dark:hover:bg-[#0f172a] hover:shadow-xl hover:shadow-slate-200/50 dark:hover:shadow-black/20 transition-all duration-300"
>
    <div
        class="h-14 w-14 shrink-0 overflow-hidden rounded-xl border border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-900"
    >
        {
            coverImage ? (
                <img
                    src={coverImage}
                    alt={title}
                    width={100}
                    height={100}
                    decoding="async"
                    loading="lazy"
                    class="h-full w-full object-cover group-hover:scale-110 transition-transform duration-500 opacity-90 group-hover:opacity-100"
                />
            ) : (
                <Image
                    src={defaultCover}
                    alt={title}
                    width={100}
                    height={100}
                    decoding="async"
                    loading="lazy"
                    class="h-full w-full object-cover group-hover:scale-110 transition-transform duration-500 opacity-90 group-hover:opacity-100"
                />
            )
        }
    </div>
    <div class="flex-1 min-w-0">
        <div class="flex items-center justify-between mb-1">
            <div class="flex items-center gap-2">
                <span
                    data-pagefind-filter="source"
                    class="text-[9px] font-black text-red-600 dark:text-red-500 uppercase tracking-widest"
                >
                    {source}
                </span>
                {tags.slice(0, 1).map((tag: string) => (
                    <span class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest px-1.5 py-0.5 rounded-sm bg-slate-50 dark:bg-slate-900 border border-slate-100 dark:border-slate-800">
                        {getTopicLabel(tag)}
                    </span>
                ))}
            </div>
            <time class="text-[9px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">
                {formattedDate}
            </time>
        </div>
        <h3
            class="text-sm font-bold text-slate-800 dark:text-slate-200 leading-tight group-hover:text-red-600 dark:group-hover:text-red-500 transition-colors line-clamp-2"
        >
            {title}
        </h3>
    </div>
</a>
