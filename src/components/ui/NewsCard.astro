---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import defaultCover from "@/assets/default-php-cover.png";

interface Props {
    item: CollectionEntry<"news">;
}

const { item } = Astro.props as Props;
---

<a
    href={item.data.link}
    class="group flex items-start gap-4 p-2 rounded-xl hover:bg-slate-50 transition-colors"
>
    <div
        class="h-16 w-16 shrink-0 overflow-hidden rounded-lg border border-slate-100"
    >
        <Image
            src={item.data.coverImage || defaultCover}
            alt=""
            width={100}
            height={100}
            class="h-full w-full object-cover group-hover:scale-110 transition-transform"
        />
    </div>
    <div>
        <span
            data-pagefind-filter="source"
            class="text-[10px] font-bold text-slate-400 uppercase tracking-tight"
            >{item.data.source}</span
        >
        <h3
            class="text-sm font-semibold text-slate-800 leading-snug group-hover:text-blue-600"
        >
            {item.data.title}
        </h3>
    </div>
</a>
