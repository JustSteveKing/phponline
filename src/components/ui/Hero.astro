---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import defaultCover from "@/assets/default-php-cover.png";

interface Props {
	item: CollectionEntry<"news">;
}

const { item } = Astro.props;
const { title, source, pubDate, coverImage } = item.data;
---

<section class="relative mb-16 overflow-hidden rounded-3xl bg-slate-900 group">
	<!-- Background Image with Overlay -->
	<div class="absolute inset-0">
		{
			coverImage ? (
				<img
					src={coverImage}
					alt=""
					width={1600}
					height={800}
					decoding="async"
					loading="lazy"
					class="h-full w-full object-cover opacity-50 transition-transform duration-700 group-hover:scale-105"
				/>
			) : (
				<Image
					src={defaultCover}
					alt=""
					width={1600}
					height={800}
					decoding="async"
					loading="lazy"
					class="h-full w-full object-cover opacity-50 transition-transform duration-700 group-hover:scale-105"
				/>
			)
		}
		<div class="absolute inset-0 bg-linear-to-t from-slate-900 via-slate-900/40 to-transparent"></div>
        <div class="absolute inset-0 bg-linear-r from-slate-900/80 via-transparent to-transparent"></div>
	</div>

	<!-- Content -->
	<div class="relative h-full min-h-[500px] flex flex-col justify-end p-8 md:p-16 max-w-4xl">
		<div class="flex items-center gap-3 mb-6">
			<span class="px-4 py-1.5 rounded-full bg-red-600 text-white text-[10px] font-black uppercase tracking-[0.2em] shadow-lg shadow-red-500/30">
				Featured Story
			</span>
			<span class="text-slate-300 text-xs font-bold uppercase tracking-widest">
				{source} • {pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
			</span>
		</div>

		<h1 class="text-4xl md:text-6xl font-black text-white leading-[1.1] tracking-tight mb-8">
			{title}
		</h1>

		<div class="flex flex-wrap items-center gap-4">
			<a
				href={`/news/${item.id}`}
				class="bg-white text-slate-900 px-8 py-4 rounded-full font-black text-sm hover:bg-red-50 transition-all flex items-center gap-2 group/btn shadow-xl"
			>
				Read the Article
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover/btn:translate-x-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
			</a>
		</div>
	</div>
	</section>
