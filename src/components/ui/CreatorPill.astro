---
import { slugify } from "@/utils/slugify";

interface Props {
    label: string;
    count: number;
    avatar?: string;
}

const { label, count, avatar } = Astro.props;
const slug = slugify(label);

// Generate a consistent but unique background for each creator (fallback)
const gradients = [
    "from-red-500 to-rose-600",
    "from-blue-500 to-indigo-600",
    "from-emerald-500 to-teal-600",
    "from-amber-500 to-orange-600",
    "from-fuchsia-500 to-purple-600",
    "from-sky-500 to-cyan-600",
];

const index = label.length % gradients.length;
const gradient = gradients[index];
---

<a
    href={`/creators/${slugify(label)}`}
    class="group relative flex items-center gap-4 p-4 pr-8 bg-white dark:bg-[#0f172a] rounded-full border border-slate-100 dark:border-slate-800/50 hover:border-red-200 dark:hover:border-red-900/30 hover:shadow-2xl hover:shadow-red-500/10 transition-all duration-500 hover:-translate-y-1"
>
    <!-- Avatar / Initial -->
    <div class={`relative w-12 h-12 rounded-full overflow-hidden flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-500 ${!avatar ? `bg-linear-to-br ${gradient} text-white font-black text-xl` : ''}`}>
        {avatar ? (
            <img src={avatar} alt={label} class="w-full h-full object-cover" />
        ) : (
            label.charAt(0)
        )}
    </div>

    <div class="flex flex-col">
        <span class="text-sm font-black text-slate-900 dark:text-white uppercase tracking-tight group-hover:text-red-600 transition-colors">
            {label}
        </span>
        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">
            {count} Videos
        </span>
    </div>

    <!-- Background Subtle Shine -->
    <div class="absolute inset-0 rounded-full bg-linear-to-r from-transparent via-white/5 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000 pointer-events-none"></div>
</a>
