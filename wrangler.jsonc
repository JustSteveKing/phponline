{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "linux",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true,
  },
  "main": "dist/_worker.js/index.js",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "dist",
  },
}
